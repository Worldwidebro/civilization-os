{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/civilization-os/.claude/hooks/pre-bash-secret-scan.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/civilization-os/.claude/hooks/post-bash-logger.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/civilization-os/.claude/hooks/session-summary.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(bash scripts/*:*)",
      "Bash(bash .claude/hooks/*:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force origin master:*)"
    ]
  }
}
